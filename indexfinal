<style>
:root{
  --bg:#FBF7F0; --fg:#2A2723; --muted:#7A736B;
  --card:#FFFFFF; --border:#EDE5D7;
  --primary:#7BA17A; --primary-deep:#3F6A4A;
  --terracotta:#C97B5A; --sun:#F2C879;
  --radius:24px;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg);color:var(--fg);font-family:'Plus Jakarta Sans',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
.container{max-width:1120px;margin:0 auto;padding:0 24px}
h1,h2,h3{font-family:'Fraunces',Georgia,serif;font-weight:600;letter-spacing:-.01em;margin:0}
h1{font-size:clamp(2.5rem,6vw,4.5rem);line-height:1.05}
h2{font-size:clamp(2rem,4vw,3rem);line-height:1.1}
p{line-height:1.6;color:var(--muted);margin:0}

/* Header */
header{padding:24px 0;display:flex;align-items:center;justify-content:space-between}
.logo{font-family:'Fraunces',serif;font-weight:600;font-size:28px;letter-spacing:1px;display:flex;align-items:center;gap:6px}
.logo .leaf{width:18px;height:18px;background:var(--primary);border-radius:50% 0 50% 50%;transform:rotate(-30deg);display:inline-block}
nav a{font-size:14px;color:var(--muted);margin-left:28px}
nav a:hover{color:var(--fg)}

/* Hero */
.hero{position:relative;overflow:hidden;background:linear-gradient(160deg,#FBF7F0 0%,#F4EBDB 60%,#EFE2CB 100%);border-radius:32px;margin-top:8px}
.hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;padding:80px 56px}
.badge{display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid var(--border);padding:6px 14px;border-radius:999px;font-size:12px;font-weight:600;color:var(--primary-deep);margin-bottom:24px}
.hero p.lead{margin-top:20px;font-size:18px;max-width:480px;color:#5d5650}
.cta-row{margin-top:32px;display:flex;gap:14px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:10px;padding:14px 26px;border-radius:999px;font-weight:600;font-size:15px;transition:transform .2s ease, box-shadow .2s ease;border:1px solid transparent}
.btn-primary{background:var(--fg);color:#fff;box-shadow:0 10px 30px -10px rgba(0,0,0,.35)}
.btn-primary:hover{transform:translateY(-2px)}
.btn-ghost{background:#fff;border-color:var(--border)}
.hero-art{position:relative;display:flex;justify-content:center}
.hero-art::before{content:"";position:absolute;inset:10%;background:radial-gradient(circle,var(--primary) 0%,transparent 70%);opacity:.18;filter:blur(40px)}
.hero-art img{position:relative;width:100%;max-width:420px;animation:float 6s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

/* Store badges */
.stores{display:flex;gap:14px;flex-wrap:wrap;margin-top:8px}
.store{display:inline-flex;align-items:center;gap:12px;background:#111;color:#fff;padding:12px 22px 12px 18px;border-radius:14px;min-width:180px;transition:transform .2s}
.store:hover{transform:translateY(-3px)}
.store svg{width:28px;height:28px;flex-shrink:0}
.store .small{font-size:10px;letter-spacing:.5px;text-transform:uppercase;opacity:.75;display:block;line-height:1.2}
.store .big{font-family:'Fraunces',serif;font-weight:600;font-size:18px;line-height:1.1}

/* Sections */
section{padding:96px 0}
.eyebrow{font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--primary-deep);font-weight:700;margin-bottom:12px}
.section-head{max-width:640px;margin-bottom:48px}
.section-head p{margin-top:14px;font-size:17px}

.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:48px;align-items:center}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:28px;transition:transform .2s, box-shadow .2s, border-color .2s}
.card:hover{transform:translateY(-4px);border-color:rgba(123,161,122,.4);box-shadow:0 20px 40px -25px rgba(0,0,0,.15)}
.card .ico{width:44px;height:44px;border-radius:12px;background:rgba(123,161,122,.15);color:var(--primary-deep);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px}
.card h3{font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:18px;margin-bottom:6px}
.card p{font-size:14px}

/* Bento modules */
.modules{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.mod{background:#fff;border:1px solid var(--border);border-radius:18px;padding:18px;font-size:13px}
.mod .emj{font-size:22px;display:block;margin-bottom:6px}
.mod strong{display:block;margin-bottom:4px;font-size:14px}
.mod span{color:var(--muted)}

/* Final CTA */
.final{background:var(--fg);color:#fff;border-radius:32px;padding:80px 40px;text-align:center;position:relative;overflow:hidden}
.final::before,.final::after{content:"";position:absolute;width:280px;height:280px;border-radius:50%;filter:blur(60px);opacity:.4}
.final::before{background:var(--primary);top:-100px;right:-80px}
.final::after{background:var(--sun);bottom:-120px;left:-80px}
.final > *{position:relative}
.final h2{color:#fff}
.final p{color:rgba(255,255,255,.7);margin:20px auto 32px;max-width:480px;font-size:17px}
.final .stores{justify-content:center}

footer{padding:32px 0;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:13px;color:var(--muted)}

@media (max-width:760px){
  .hero-inner{grid-template-columns:1fr;padding:48px 28px;text-align:center}
  .hero-art{order:-1}
  .cta-row{justify-content:center}
  .grid-3,.grid-2{grid-template-columns:1fr;gap:20px}
  .modules{grid-template-columns:repeat(2,1fr)}
  nav{display:none}
  section{padding:64px 0}
}
</style>
</head>
